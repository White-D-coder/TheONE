generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String            @id @default(cuid())
  email         String            @unique
  name          String?
  roleWeights   Json?
  currentMode   String            @default("NORMAL")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  applications  Application[]
  logs          DailyLog[]
  events        EventLog[]
  evidences     Evidence[]
  opportunities Opportunity[]
  accounts      PlatformAccount[]
  drafts        PostDraft[]
  projects      Project[]
  routines      Routine[]
  skills        Skill[]
  speaking      SpeakingSession[]
  worthHistory  WorthRecord[]
  streaks       Streak[]
  contentItems  ContentItem[]
  routinePrefs  Json?
}

model PlatformAccount {
  id          String    @id @default(cuid())
  userId      String
  platform    String
  username    String
  accessToken String?
  lastSynced  DateTime?
  syncStatus  String    @default("IDLE")
  stats       Json?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
}

model Skill {
  id               String   @id @default(cuid())
  userId           String
  name             String
  category         String
  score            Float    @default(0)
  confidenceScore  Float    @default(0)
  consistencyScore Float    @default(0)
  evidenceCount    Int      @default(0)
  lastPracticedAt  DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id])
  evidences        Evidence[]
}

model Evidence {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  description String?
  url         String?
  strength    Float
  source      String   @default("MANUAL")
  skillId     String?
  projectId   String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  skill       Skill?   @relation(fields: [skillId], references: [id])
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  name        String
  stage       String
  techStack   Json?
  visibility  String   @default("PRIVATE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  description String?
  githubRepo  String?
  user        User     @relation(fields: [userId], references: [id])
}

model DailyLog {
  id           String   @id @default(cuid())
  userId       String
  date         DateTime @default(now())
  workBlocks   Json?
  distractions Int      @default(0)
  energy       Int      @default(5)
  focusScore   Float    @default(0)
  summary      String?
  user         User     @relation(fields: [userId], references: [id])
}

model Routine {
  id        String   @id @default(cuid())
  userId    String
  name      String
  blocks    Json
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model SpeakingSession {
  id         String   @id @default(cuid())
  userId     String
  topic      String
  transcript String?
  audioUrl   String?
  scores     Json?
  feedback   String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model Opportunity {
  id        String   @id @default(cuid())
  userId    String
  title     String
  company   String
  location  String?
  salary    String?
  url       String?
  source    String   @default("SCRAPER")
  status    String   @default("DISCOVERED")
  fitScore  Float
  reason    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Application {
  id          String   @id @default(cuid())
  userId      String
  oppId       String?
  title       String
  company     String
  status      String   @default("DRAFT")
  resumeUrl   String?
  coverLetter String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model PostDraft {
  id           String   @id @default(cuid())
  userId       String
  platform     String
  content      String
  status       String   @default("DRAFT")
  evidenceId   String?
  publishedUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
}

model WorthRecord {
  id        String   @id @default(cuid())
  userId    String
  month     Int
  year      Int
  score     Float
  breakdown Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model ContentItem {
  id        String   @id @default(cuid())
  userId    String   @default("elite-student-id")
  title     String
  url       String   @unique
  source    String
  category  String
  summary   String?
  relevance Float    @default(0)
  status    String   @default("UNREAD")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model EventLog {
  id        String   @id @default(cuid())
  userId    String
  type      String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Streak {
  id           String   @id @default(cuid())
  userId       String
  type         String   // CODE, DSA, CONTENT, ROUTINE
  currentCount Int      @default(0)
  longestCount Int      @default(0)
  lastUpdate   DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}
